# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=researchpilot

# HTTP listen
BIND_ADDR=127.0.0.1:8000

# Default LLM
LLM_MODEL=deepseek-v4-flash

# Provider 1: local OpenAI-compatible proxy (read from frontend's .env.local too)
LLM_BASE_URL=http://localhost:8317/v1
LLM_API_KEY=sk-REPLACE_WITH_YOUR_LOCAL_KEY

# Provider 2: opencode-go fallback
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_API_KEY=sk-REPLACE_WITH_YOUR_OPENCODE_KEY

# Extra fallback providers (optional). Define up to 16 by number.
# Empty _MODELS = wildcard (used for any model). Comma-separated _MODELS
# claims ownership of those models, putting this provider first when one
# is requested. Providers are tried in order until one returns success.
#
# LLM_PROVIDER_1_NAME=deepseek_direct
# LLM_PROVIDER_1_BASE_URL=https://api.deepseek.com/v1
# LLM_PROVIDER_1_API_KEY=sk-...
# LLM_PROVIDER_1_MODELS=deepseek-v4-flash,deepseek-chat
#
# LLM_PROVIDER_2_NAME=anthropic_compat
# LLM_PROVIDER_2_BASE_URL=https://example.com/v1
# LLM_PROVIDER_2_API_KEY=sk-...
