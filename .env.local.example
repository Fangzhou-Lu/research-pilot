# Default model. Routed to whichever provider below serves it.
LLM_MODEL=deepseek-v4-flash

# Provider 1: local OpenAI-compatible proxy
LLM_BASE_URL=http://localhost:8317/v1
LLM_API_KEY=

# Provider 2: opencode-go (or any other OpenAI-compatible upstream).
# Set OPENCODE_BASE_URL when ready to enable fallback routing.
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
